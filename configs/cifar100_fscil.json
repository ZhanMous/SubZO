{
    "dataset": "cifar100",
    "model": "vgg9snn",
    "time_steps": 4,
    "num_classes": 100,
    "base_session": {
        "num_classes": 60,
        "epochs": 300,
        "batch_size": 128,
        "optimizer": "adam",
        "lr": 0.001,
        "scheduler": "cosine",
        "lamb": 0.05,
        "means": 5
    },
    "incremental_sessions": {
        "num_sessions": 8,
        "ways": 5,
        "shots": 5,
        "epochs": 100
    },
    "neuron": {
        "init_thresh": 1.0,
        "tau": 0.5,
        "adaptive_ratio": 0.5,
        "beta": 0.1,
        "theta": 0.01,
        "tau_decay": 100
    },
    "classifier": {
        "shift_weight": 0.1,
        "temperature": 16
    }
}
